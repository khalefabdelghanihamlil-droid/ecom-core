# ============ ECOM-CORE — Variables d'environnement ============
# Copier ce fichier en `.env` et renseigner les valeurs réelles.

# --- Base de données Supabase (REQUIS) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=sb_secret_xxx            # clé service_role

# --- Serveur ---
PORT=3000
NODE_ENV=production

# --- Sécurité Webhook Shopify (REQUIS en production) ---
SHOPIFY_WEBHOOK_SECRET=

# --- Fournisseur SMS / OTP (requis pour l'envoi réel des codes) ---
SMS_PROVIDER_URL=
SMS_PROVIDER_KEY=

# --- Transporteurs (true/false pour activer) ---
ENABLE_YALIDINE=true
ENABLE_ZR_EXPRESS=true
ENABLE_DHD_EXPRESS=true

# --- Clés API transporteurs (quand comptes réels disponibles) ---
YALIDINE_API_KEY=
YALIDINE_API_TOKEN=
ZR_API_KEY=
DHD_API_KEY=

# --- Authentification Admin (Single Login) ---
# JWT_SECRET : chaîne aléatoire longue (ex: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`)
JWT_SECRET=
JWT_EXPIRES_IN=12h
ADMIN_USERNAME=admin
# Fournir SOIT un hash bcrypt (recommandé), SOIT un mot de passe en clair.
# Générer un hash : node -e "console.log(require('bcryptjs').hashSync('VOTRE_MDP', 10))"
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD=

# --- CORS (production) : origine(s) autorisée(s) du dashboard, séparées par des virgules ---
# Exemple : CORS_ORIGIN=https://mon-dashboard.example.com
CORS_ORIGIN=
